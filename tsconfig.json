{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  },
  "references": [
    { "path": "./tsconfig.main.json", "composite": true },
    { "path": "./tsconfig.preload.json", "composite": true },
    {
      "path": "./tsconfig.renderer.json",
      "composite": true,
      "disableSourceOfProjectReferenceRedirect": true
    }
  ]
}
